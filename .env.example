# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=file:./data/aicomic.db

# ── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── LLM / Text Providers ────────────────────────────────────────────────────
# OpenAI (also used as fallback for image generation, SenseNova text)
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GEMINI_API_KEY=...

# Separate image-generation endpoint (OpenAI-compatible)
# IMAGEGEN_API_KEY=...
# IMAGEGEN_BASE_URL=...

# ── Image Generation ─────────────────────────────────────────────────────────
# Kling
# KLING_ACCESS_KEY=...
# KLING_SECRET_KEY=...

# DashScope (百炼)
# DASHSCOPE_API_KEY=...
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# DASHSCOPE_IMAGE_MODEL=qwen-image-2.0-pro

# SiliconFlow
# SILICONFLOW_API_KEY=...
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn
# SILICONFLOW_IMAGE_MODEL=black-forest-labs/FLUX.1-dev

# ComfyUI (image + video)
# COMFYUI_BASE_URL=https://...
# COMFYUI_MODEL=hidream-o1-comfyui (default; z-image-turbo-comfyui, ideogram4-comfyui, qwen-edit-dual also supported)
# COMFYUI_AUTH_TOKEN=...
# COMFYUI_AUTH_COOKIE=...

# ── Video Generation ─────────────────────────────────────────────────────────
# Seedance
# SEEDANCE_API_KEY=...
# SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com
# SEEDANCE_MODEL=doubao-seedance-1-5-pro-250528

# UCloud Seedance
# UCLOUD_API_KEY=...

# Wan (阿里云百炼视频)
# WAN_API_KEY=...
# WAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# WAN_MODEL=wan2.1-i2v-plus

# AI Video Maker
# AIVIDEO_API_KEY=...

# Agnes AI (text, image, video)
# AGNES_API_KEY=...

# ComfyUI video output dir (default: M:\ComfyUI_windows_portable\ComfyUI\output on Windows, ./comfyui-output on other platforms)
# COMFYUI_OUTPUT_DIR=...
# ComfyUI LTX checkpoint (default: LTX2.3/ltx-2.3-22b-dev-fp8.safetensors)
# COMFYUI_LTX_CHECKPOINT=...

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required for stable signed user cookies across middleware/API runtimes and server restarts.
# AUTH_SECRET=your-secret-here

# ── Video ────────────────────────────────────────────────────────────────────
# FFMPEG_BINARY_PATH=/usr/bin/ffmpeg (optional pin, prevents PATH/FFMPEG_PATH injection)
# FFMPEG_VIDEO_ENCODER=h264_nvenc (GPU encoding with NVIDIA NVENC; default: libx264 CPU)

# ── Embedding ────────────────────────────────────────────────────────────────
# Separate OpenAI-compatible endpoint for text embeddings (vector search).
# Falls back to OPENAI_BASE_URL / OPENAI_API_KEY if not set.
# EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
# EMBEDDING_API_KEY=nvapi-...
# EMBEDDING_MODEL=nvidia/nv-embed-v1

# ── Other ────────────────────────────────────────────────────────────────────
# TTS voice (default: zh-CN-XiaoxiaoNeural)
# TTS_VOICE=zh-CN-XiaoxiaoNeural
